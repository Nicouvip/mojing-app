<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>墨境有声书工坊</title>
  <link rel="stylesheet" href="/static/style.css?v=15" />
</head>
<body>
  <header class="header">
    <div class="header-left">
      <img src="/static/assets/logo-mojing.png" alt="墨境" style="height:36px;">
      <span class="project-name" id="projectName">墨境有声书工坊</span>
    </div>
    <div class="header-center" id="headerCenter">
      <button class="tool-item" onclick="showSettingsModal()"><span class="tool-icon">⚙️</span><span class="tool-label">设置</span></button>
      <div class="tool-sep"></div>
      <button class="tool-item" onclick="batchGenerateAll()"><span class="tool-icon">🚀</span><span class="tool-label">全部生成</span></button>
      <button class="tool-item" onclick="mergeAllAudios()"><span class="tool-icon">📦</span><span class="tool-label">合并导出</span></button>
      <button class="tool-item" onclick="exportMP3()"><span class="tool-icon">🎵</span><span class="tool-label">导出MP3</span></button>
      <button class="tool-item" onclick="exportSRT()"><span class="tool-icon">📝</span><span class="tool-label">导出字幕</span></button>
    </div>
    <div class="header-right">
      <button class="btn btn-sm btn-primary" onclick="showImportModal()">+ 新建作品</button>
    </div>
  </header>

  <div class="toolbar" id="toolbar">
    <button class="tool-item active" onclick="previewAll()"><img src="/static/assets/icons/Play.svg" width="24" height="24"><span class="tool-label">试听</span></button>
    <button class="tool-item" onclick="insertPause()"><img src="/static/assets/icons/Pause.svg" width="24" height="24"><span class="tool-label">停顿</span></button>
    <button class="tool-item" onclick="insertSoundEffect()"><img src="/static/assets/icons/Ventilation.svg" width="24" height="24"><span class="tool-label">换气</span></button>
    <div class="tool-sep"></div>
    <button class="tool-item" onclick="runAIAnalysis()"><img src="/static/assets/icons/Multiplayer.svg" width="24" height="24"><span class="tool-label">AI分析</span></button>
    <button class="tool-item" onclick="addNarrator()"><span class="tool-icon">📖</span><span class="tool-label">+旁白</span></button>
    <button class="tool-item" onclick="addCharacter()"><span class="tool-icon">👤</span><span class="tool-label">+角色</span></button>
    <div class="tool-sep"></div>
    <button class="tool-item" onclick="batchGenerateAll()"><img src="/static/assets/icons/VariableSpeed.svg" width="24" height="24"><span class="tool-label">批量生成</span></button>
    <button class="tool-item" onclick="mergeAllAudios()"><img src="/static/assets/icons/ImportFile.svg" width="24" height=\"24\"><span class=\"tool-label\">合并导出</span></button>
  </div>

  <!-- 主编辑区 -->
  <div class="editor-main">
    <!-- 左栏：文本输入 -->
    <div class="editor-left">
      <!-- 作品+章节选择器 -->
      <div class="source-box">
        <div class="source-top">
          <select id="projectSelect" class="select-sm" onchange="onProjectChange()" style="min-width:140px;">
            <option value="">选择作品...</option>
          </select>
          <select id="chapterSelect" class="select-sm" onchange="onChapterChange()">
            <option value="all">全部章节</option>
          </select>
          <span class="source-info" id="sourceInfo"></span>
        </div>
        <textarea id="sourceText" class="source-textarea" rows="6" placeholder="选择章节后文本自动填入，或直接粘贴文本..."></textarea>
      </div>

      <!-- 角色列表 -->
      <div class="char-toolbar">
        <span class="char-toolbar-label">角色列表</span>
        <span class="badge" id="charCount">0</span>
      </div>
      <div class="char-list" id="charList">
        <div class="empty-hint">点击上方「+旁白」或「+角色」添加，或使用「AI分析」自动识别</div>
      </div>
    </div>

    <!-- 右栏：音色选择 -->
    <div class="editor-right">
      <div class="voice-tabs">
        <button class="voice-tab active" onclick="switchVoiceTab(this,'all')">全部主播</button>
        <button class="voice-tab" onclick="switchVoiceTab(this,'hot')">我的收藏</button>
        <button class="voice-tab" onclick="switchVoiceTab(this,'custom')">自定义</button>
      </div>
      <div class="voice-search">
        <input type="text" placeholder="搜索音色..." oninput="searchVoices(this.value)">
      </div>
      <div class="voice-filters" id="voiceFilters">
        <button class="vfilter active" data-filter="all" onclick="filterVoices('all')">全部</button>
        <button class="vfilter" data-filter="super" onclick="filterVoices('super')">✨ 超拟人</button>
        <button class="vfilter" data-filter="narrate" onclick="filterVoices('narrate')">📖 解说</button>
        <button class="vfilter" data-filter="emotion" onclick="filterVoices('emotion')">💓 情感</button>
        <button class="vfilter" data-filter="dialect" onclick="filterVoices('dialect')">🗣 方言</button>
        <button class="vfilter" data-filter="kid" onclick="filterVoices('kid')">👶 童声</button>
      </div>
      <div class="voice-list" id="voiceCards"></div>
    </div>
  </div>

  <!-- 底部播放器 -->
  <div id="playerBar" class="player-bar" style="display:none;">
    <div class="player-left">
      <button class="player-btn" onclick="playerPrev()">⏮</button>
      <button class="player-btn player-play" id="playerPlayBtn" onclick="playerToggle()">▶</button>
      <button class="player-btn" onclick="playerNext()">⏭</button>
    </div>
    <div class="player-center">
      <div class="player-title" id="playerTitle">未播放</div>
      <div class="player-progress-wrap" onclick="playerSeek(event)">
        <div class="player-progress-track"><div class="player-progress-fill" id="playerProgress"></div></div>
      </div>
      <div class="player-time" id="playerTime">00:00 / 00:00</div>
    </div>
    <div class="player-right"><a id="playerDownload" class="btn btn-sm" download>💾 下载</a></div>
  </div>

  <!-- 弹窗 -->
  <div class="modal-overlay" id="importModal" style="display:none;" onclick="closeModal(event,'importModal')">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header"><h3>📚 新建作品</h3><button class="modal-close" onclick="hideModal('importModal')">✕</button></div>
      <div class="modal-body">
        <div class="form-group"><label>作品名称</label><input type="text" id="importTitle" class="form-input" placeholder="例如：我的小说有声书"></div>
        <div class="form-group"><label>分章模式</label><div class="radio-group"><label class="radio"><input type="radio" name="splitMode" value="smart" checked> 智能分章</label><label class="radio"><input type="radio" name="splitMode" value="paragraph"> 按段落</label><label class="radio"><input type="radio" name="splitMode" value="none"> 不分章</label></div></div>
        <div class="form-group"><label>小说文本</label><textarea id="importText" class="form-textarea" rows="8" placeholder="粘贴小说文本或上传文件..."></textarea><label class="btn btn-sm btn-secondary upload-label" for="importFile">📂 上传TXT</label><input type="file" id="importFile" accept=".txt,.md" hidden onchange="handleImportFile(event)"></div>
      </div>
      <div class="modal-footer"><button class="btn" onclick="hideModal('importModal')">取消</button><button class="btn btn-primary" onclick="submitImport()">创建作品</button></div>
    </div>
  </div>
  <div class="modal-overlay" id="settingsModal" style="display:none;" onclick="closeModal(event,'settingsModal')">
    <div class="modal" onclick="event.stopPropagation()">
      <div class="modal-header"><h3>⚙️ 设置</h3><button class="modal-close" onclick="hideModal('settingsModal')">✕</button></div>
      <div class="modal-body">
        <div class="form-group"><label>默认情绪</label><select id="settingEmotion" class="form-input"></select></div>
        <div class="form-group"><label>对话间隔 (ms)</label><input type="number" id="settingPause" class="form-input" value="500" min="0" max="3000"></div>
      </div>
      <div class="modal-footer"><button class="btn" onclick="hideModal('settingsModal')">关闭</button></div>
    </div>
  </div>
  <div id="toast" class="toast" style="display:none;"></div>
  <script src="/static/app.js?v=15"></script>
</body>
</html>
