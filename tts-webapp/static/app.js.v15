  { id: "大叔", name: "大叔", avatar: "/static/assets/avatars/大叔.png", lang: "zh", gender: "male", desc: "沧桑大叔", tag: "narrate" },
  { id: "川妹子", name: "川妹子", avatar: "/static/assets/avatars/川妹子.png", lang: "zh", gender: "female", desc: "四川方言", tag: "dialect" },
  { id: "东北哥", name: "东北哥", avatar: "/static/assets/avatars/东北哥.png", lang: "zh", gender: "male", desc: "东北方言", tag: "dialect" },
  { id: "粤语妹", name: "粤语妹", avatar: "/static/assets/avatars/粤语妹.png", lang: "zh", gender: "female", desc: "粤语女声", tag: "dialect" },
  { id: "播客男", name: "播客男", avatar: "/static/assets/avatars/播客男.png", lang: "zh", gender: "male", desc: "播客主播", tag: "narrate" },
  { id: "Mia", name: "Mia", avatar: "/static/assets/avatars/Mia.png", lang: "en", gender: "female", desc: "English Female", tag: "super" },
