  { id: "苏打", name: "苏打", avatar: "/static/assets/avatars/苏打.png", lang: "zh", gender: "male", desc: "阳光男声", tag: "narrate", hot: true },
  { id: "白桦", name: "白桦", avatar: "/static/assets/avatars/白桦.png", lang: "zh", gender: "male", desc: "沉稳男声", tag: "narrate" },
  { id: "青柠", name: "青柠", avatar: "/static/assets/avatars/青柠.png", lang: "zh", gender: "female", desc: "活泼少女", tag: "emotion", hot: true },
